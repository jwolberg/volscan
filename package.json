{
  "name": "volscan",
  "version": "1.0.0",
  "description": "Options market intelligence dashboard",
  "scripts": {
    "dev": "npm install && concurrently -n proxy,vite -c cyan,green \"node proxy/server.js\" \"vite\"",
    "proxy": "node proxy/server.js",
    "start": "concurrently \"npm run proxy\" \"npm run dev\"",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.2"
  }
}
